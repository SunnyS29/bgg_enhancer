{
  "manifest_version": 3,
  "name": "BGG Price Compare AU",
  "version": "2.0.0",
  "description": "Compare Australian board game store prices on BoardGameGeek",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://boardgamegeek.com/*",
    "https://www.boardgamegeek.com/*",
    "https://www.ebay.com.au/*",
    "https://www.gameology.com.au/*",
    "https://www.guf.com.au/*",
    "https://www.boardgamemaster.com.au/*",
    "https://www.gamesempire.com.au/*",
    "https://www.goodgames.com.au/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://boardgamegeek.com/boardgame/*",
        "*://www.boardgamegeek.com/boardgame/*"
      ],
      "js": ["src/utils.js", "src/panel.js", "src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
